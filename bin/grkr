#!/bin/bash
set -e

resolve_script_path() {
  local source_path=$1
  local source_dir

  while [ -L "$source_path" ]; do
    source_dir=$(cd "$(dirname "$source_path")" && pwd)
    source_path=$(readlink "$source_path")
    case "$source_path" in
      /*) ;;
      *) source_path="$source_dir/$source_path" ;;
    esac
  done

  printf '%s\n' "$source_path"
}

SCRIPT_PATH=$(resolve_script_path "${BASH_SOURCE[0]}")
SCRIPT_DIR=$(cd "$(dirname "$SCRIPT_PATH")" && pwd)
. "$SCRIPT_DIR/doctor.sh"
. "$SCRIPT_DIR/grkr-project-status.sh"
. "$SCRIPT_DIR/grkr-issue-workflow.sh"
. "$SCRIPT_DIR/lib/refusal_paths.sh"
. "$SCRIPT_DIR/lib/task_progress.sh"
. "$SCRIPT_DIR/lib/linear_issue.sh"
. "$SCRIPT_DIR/lib/github_issue.sh"
. "$SCRIPT_DIR/grkr-task-slug.sh"

usage() {
  local exit_code=${1:-1}
  echo "Usage: grkr init <project-id> | grkr --issue <number> | grkr --linear-issue <identifier> | grkr --project <id>"
  echo "Example: grkr init 42"
  echo "Example: grkr --issue 1"
  echo "Example: grkr --linear-issue ENG-123"
  echo "Example: grkr --project 42"
  exit "$exit_code"
}

case "${1:-}" in
  --help|-h|help)
    usage 0
    ;;
esac

mkdir -p "${HOME:-.}/.grkr/logs"
LOGFILE="${HOME:-.}/.grkr/logs/grkr-$(date +%Y%m%d-%H%M%S).log"
CURRENT_ISSUE=""
CURRENT_PROMPT_FILE=""
CURRENT_ISSUE_WORKTREE=""
ATTACH_ISSUE_LOGS=0
PR_URL=""
BRANCH_URL=""
if command -v tee >/dev/null 2>&1; then
  LOG_PIPE=$(mktemp "${TMPDIR:-/tmp}/grkr-log.XXXXXX")
  rm -f "$LOG_PIPE"
  mkfifo "$LOG_PIPE"
  tee -a "$LOGFILE" < "$LOG_PIPE" &
  LOG_TEE_PID=$!
  exec >"$LOG_PIPE" 2>&1
else
  exec >>"$LOGFILE" 2>&1
fi
MAX_FILE_LINES=1000
MAX_PR_BODY_CHARS=60000
VALIDATION_OK=0
TASKS_DIR=""
. "$SCRIPT_DIR/grkr-templates.sh"

MODE=${1:-}
case "$MODE" in
  init)
    [ -n "${2:-}" ] || usage
    ID="$2"
    ;;
  --issue|--project|--linear-issue)
    [ -n "${2:-}" ] || usage
    ID="$2"
    ;;
  *)
    usage
    ;;
esac

attach_issue_logs() {
  local issue=${CURRENT_ISSUE:-}
  local comment_file
  [ -n "$issue" ] || return 0
  [ -f "$LOGFILE" ] || return 0
  comment_file=$(mktemp "${TMPDIR:-/tmp}/grkr-issue-log.XXXXXX") || return 0
  {
    printf '<details>\n<summary>Execution log</summary>\n\n```text\n'
    cat "$LOGFILE"
    printf '\n```\n</details>\n'
  } > "$comment_file"
  gh issue comment "$issue" --body-file "$comment_file" >/dev/null 2>&1 || true
  rm -f "$comment_file"
}

cleanup_on_exit() {
  [ -n "${CURRENT_PROMPT_FILE:-}" ] && rm -f "$CURRENT_PROMPT_FILE" 2>/dev/null || true
  if [ "${ATTACH_ISSUE_LOGS:-0}" -eq 1 ]; then
    attach_issue_logs
  fi
  [ -n "${LOG_PIPE:-}" ] && rm -f "$LOG_PIPE" 2>/dev/null || true
  [ -n "${LOG_TEE_PID:-}" ] && kill "$LOG_TEE_PID" 2>/dev/null || true
}

trap cleanup_on_exit EXIT

if [ "$MODE" = "init" ]; then
  doctor_init
  if doctor_create_config "$ID"; then
    echo "✅ Created config: $GRKR_CONFIG_FILE"
    exit 0
  fi
  exit 1
fi

if doctor_validate "$MODE" "$ID"; then
  VALIDATION_OK=1
fi

if [ "$MODE" = "--issue" ]; then
  ISSUE="$ID"
fi

if [ "$MODE" = "--linear-issue" ]; then
  LINEAR_ISSUE_ID="$ID"
fi

if [ "$VALIDATION_OK" -eq 1 ]; then
  if [ -n "$(git status --porcelain --untracked-files=all | grep -vE '^.. \.grkr(/|$)')" ]; then
    echo "⚠️ Working directory is not clean. Continuing with the existing changes in the worktree."
  fi
fi

collect_file_line_limit_violations() {
  local file
  local line_count

  while IFS= read -r -d '' file; do
    [ -n "$file" ] || continue
    line_count=$(git_in_issue_context show ":$file" | wc -l | tr -d '[:space:]')
    if [ "$line_count" -gt "$MAX_FILE_LINES" ]; then
      printf '%s\t%s\n' "$file" "$line_count"
    fi
  done < <(git_in_issue_context diff --cached --name-only --diff-filter=ACMR -z)
}

check_file_line_limit() {
  local file
  local line_count
  local violations=0

  while IFS="$(printf '\t')" read -r file line_count; do
    [ -n "$file" ] || continue
    echo "❌ $file has $line_count lines. Files must be $MAX_FILE_LINES lines or fewer."
    violations=1
  done < <(collect_file_line_limit_violations)

  return $violations
}


run_progress_cli() {
  local project_root
  project_root=${GRKR_GLEAM_PROJECT_ROOT:-$(dirname "$SCRIPT_DIR")}

  if [ -f "$project_root/gleam.toml" ]; then
    (cd "$project_root" && gleam run -m grkr/progress/cli -- "$@")
    return
  fi

  case "${1:-}" in
    marker)
      printf '<!-- grkr:checkpoint stage=%s task=%s version=1 -->' "$2" "$3"
      ;;
    *)
      printf 'Missing Gleam project root for grkr progress CLI: %s\n' "$project_root" >&2
      return 1
      ;;
  esac
}

checkpoint_marker() {
  local stage=$1
  local task_slug=$2

  run_progress_cli marker "$stage" "$task_slug"
}

build_command_list() {
  local command_count=0

  if [ -n "${BUILD_COMMAND:-}" ]; then
    printf '%s\n' "$BUILD_COMMAND"
    command_count=$((command_count + 1))
  fi

  if [ -n "${TEST_COMMAND:-}" ]; then
    printf '%s\n' "$TEST_COMMAND"
    command_count=$((command_count + 1))
  fi

  if [ "$command_count" -eq 0 ]; then
    printf '%s\n' "npm test"
  fi
}

cleanup_test_result_logs() {
  local results_file=$1
  local log_file

  [ -f "$results_file" ] || return 0
  while IFS="$(printf '\t')" read -r _ _ log_file; do
    [ -n "$log_file" ] || continue
    rm -f "$log_file"
  done < "$results_file"
}

# Shared body writer for test checkpoint (thin reuse for GitHub + Linear).
# GitHub callers use write_test_checkpoint_file (preserves "Issue #N: title" + gh behavior).
# Linear calls this directly with "Linear issue ID: title" (no # on identifier).
# All sections, marker, excerpts, risks, recommendation identical.
# Extracted per design-linear-test-stage.md to avoid duplication while keeping GitHub ensure_test_checkpoint 100% unchanged.
write_test_checkpoint_with_header() {
  local checkpoint_file=$1
  local header_line=$2
  local task_slug=$3
  local commands_file=$4
  local results_file=$5
  local recommendation=$6
  local overall_result=$7
  local total_commands=$8
  local passed_commands=$9
  local failed_commands=${10}

  {
    printf '%s\n\n' "$(checkpoint_marker test "$task_slug")"
    printf '## Test checkpoint\n\n'
    printf '%s\n\n' "$header_line"

    printf '### Commands run\n\n'
    while IFS= read -r command; do
      [ -n "$command" ] || continue
      printf -- '- `%s`\n' "$command"
    done < "$commands_file"
    printf '\n'

    printf '### Pass/fail summary\n\n'
    printf -- '- Overall result: %s\n' "$overall_result"
    printf -- '- Commands passed: %s/%s\n' "$passed_commands" "$total_commands"
    if [ "$failed_commands" -gt 0 ]; then
      printf -- '- Commands failed: %s\n' "$failed_commands"
    fi
    while IFS="$(printf '\t')" read -r status command _; do
      [ -n "$command" ] || continue
      printf -- '- `%s`: %s\n' "$command" "$status"
    done < "$results_file"
    printf '\n'

    printf '### Output excerpts\n\n'
    while IFS="$(printf '\t')" read -r status command log_file; do
      [ -n "$command" ] || continue
      printf '#### `%s`\n\n' "$command"
      printf '```text\n'
      if [ -s "$log_file" ]; then
        sed -n '1,20p' "$log_file"
        if [ "$(wc -l < "$log_file" | tr -d '[:space:]')" -gt 20 ]; then
          printf '...\n'
        fi
      else
        printf '(no output)\n'
      fi
      printf '```\n\n'
    done < "$results_file"

    printf '### Remaining risks\n\n'
    if [ "$failed_commands" -gt 0 ]; then
      printf -- '- At least one configured verification command failed; inspect the command output above before merging.\n'
    fi
    printf -- '- The checkpoint covers only the configured local verification commands; GitHub-side checks and broader manual validation may still be pending.\n\n'

    printf '### Recommendation\n\n'
    printf '%s\n' "$recommendation"
  } > "$checkpoint_file"
}

summarize_text() {
  local text=$1
  local max_chars=$2

  printf '%s' "$text" \
    | tr '\n' ' ' \
    | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//' \
    | awk -v limit="$max_chars" '
        {
          if (length($0) <= limit) {
            print $0
          } else if (limit > 3) {
            print substr($0, 1, limit - 3) "..."
          } else {
            print substr($0, 1, limit)
          }
        }
      '
}

run_codex_prompt() {
  local prompt_file=$1
  local output_file=$2
  local phase_label=$3
  local mode=${4:-replace}
  local workdir=${5:-$(pwd)}
  local run_output_file

  run_output_file=$(mktemp "${TMPDIR:-/tmp}/grkr-codex-output.XXXXXX")
  echo "🚀 Running codex to $phase_label..."
  echo "Prompt saved to $prompt_file for reference."
  codex exec --full-auto --cd "$workdir" < "$prompt_file" >"$run_output_file" 2>&1
  cat "$run_output_file"
  echo ""

  persist_task_log_output "$run_output_file" "$output_file" "$phase_label" "$mode"
  echo "✅ codex has finished $phase_label."
}

ensure_publishable_file_sizes() {
  local issue=$1
  local title=$2
  local task_slug=$3
  local prompt_file=$4
  local codex_output_file=$5
  local violations

  stage_relevant_issue_files
  if git_in_issue_context diff --cached --quiet; then
    return 0
  fi

  violations=$(collect_file_line_limit_violations)
  if [ -z "$violations" ]; then
    return 0
  fi

  check_file_line_limit
  echo "🔧 Staged files exceed the $MAX_FILE_LINES-line limit. Asking codex to refactor before publish."
  write_line_limit_fix_prompt "$prompt_file" "$issue" "$title" "$task_slug" "$violations"
  run_codex_prompt "$prompt_file" "$codex_output_file" "remediate file line-limit violations" append "${CURRENT_ISSUE_WORKTREE:-$(pwd)}"

  stage_relevant_issue_files
  if check_file_line_limit; then
    return 0
  fi

  echo "❌ Commit aborted due to file size limit."
  return 1
}

process_issue() {
  local ISSUE=$1
  GITHUB_IMPL_REFUSED=0
  # 1. validate + fetch + task dir/progress bootstrap (lib helper)
  bootstrap_github_issue_task "$ISSUE" || return 1
  # 2. research/plan checkpoints (already in lib)
  ensure_checkpoint_stage research "$ISSUE" "$ISSUE_JSON" "$TASK_SLUG" "$TASK_DIR" "$TITLE" "$BODY" "$URL" "$PROGRESS_FILE" || return 1
  ensure_checkpoint_stage plan "$ISSUE" "$ISSUE_JSON" "$TASK_SLUG" "$TASK_DIR" "$TITLE" "$BODY" "$URL" "$PROGRESS_FILE" || return 1
  # 3. prepare worktree + decision codex + decision_gate (lib helper)
  run_github_decision_stage || return 1
  # 4. refuse path cleanup (lib helper) OR proceed
  if [ "${IMPLEMENTATION_DECISION:-}" != "proceed" ]; then
    handle_github_decision_refuse
    return 0
  fi
  # 5. move in progress + implement codex + implementation-refusal path (lib helper)
  run_github_implement_stage || {
    CURRENT_ISSUE_WORKTREE=""
    return 1
  }
  if [ "${GITHUB_IMPL_REFUSED:-0}" = "1" ]; then
    return 0
  fi
  # 6. ensure_publishable_file_sizes (shared; stays in grkr)
  ensure_publishable_file_sizes "$ISSUE" "$TITLE" "$TASK_SLUG" "$CURRENT_PROMPT_FILE" "$TASK_DIR/implementation.log" || {
    CURRENT_ISSUE_WORKTREE=""
    return 1
  }
  # 7. ensure_test_checkpoint (lib)
  ensure_test_checkpoint "$ISSUE" "$ISSUE_JSON" "$TASK_SLUG" "$TASK_DIR" "$TITLE" "$PROGRESS_FILE" || {
    CURRENT_ISSUE_WORKTREE=""
    return 1
  }
  # 8. publish_issue_changes (lib)
  if ! publish_issue_changes "$ISSUE" "$TITLE" "$URL" "$BODY" "$TASK_DIR/implementation.log" "$BRANCH"; then
    CURRENT_ISSUE_WORKTREE=""
    echo "⚠️ Issue #$ISSUE changes were not published."
    return 1
  fi
  # 9. mark complete + move done + post_completion (thin calls / small lib helper)
  finalize_github_issue_complete
  # 10. attach logs (via finalize)
}

if [ "$MODE" = "--project" ]; then
  PROJECT="$ID"
  echo "🔄 Starting infinite loop watcher for project $PROJECT..."
  while true; do
    if [ "$VALIDATION_OK" -ne 1 ]; then
      echo "⚠️ Validation failed; skipping mutating operations."
      echo "⏳ Sleeping 30 seconds..."
      sleep 30
      continue
    fi
    echo "🔍 Querying issues in todo state..."
    TODO_ISSUES=$(gh issue list --state open --json number,title,projectItems | jq -r --arg todo "$TODO_VALUE" '.[] | select(.projectItems | any(.status.name == $todo)) | .number')
    for ISSUE in $TODO_ISSUES; do
      echo "📋 Found todo issue #$ISSUE, implementing..."
      if ! process_issue "$ISSUE"; then
        echo "⚠️ Issue #$ISSUE failed during processing. Continuing to the next issue."
      fi
    done
    echo "⏳ Sleeping 30 seconds..."
    sleep 30
  done
fi

if [ "$MODE" = "--issue" ]; then
  process_issue "$ISSUE"
fi

if [ "$MODE" = "--linear-issue" ]; then
  process_linear_issue "$LINEAR_ISSUE_ID"
fi
