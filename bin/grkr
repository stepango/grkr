#!/bin/bash
set -e

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
. "$SCRIPT_DIR/doctor.sh"

mkdir -p "${HOME:-.}/.grkr/logs"
LOGFILE="${HOME:-.}/.grkr/logs/grkr-$(date +%Y%m%d-%H%M%S).log"
CURRENT_ISSUE=""
CURRENT_PROMPT_FILE=""
ATTACH_ISSUE_LOGS=0
if command -v tee >/dev/null 2>&1; then
  LOG_PIPE=$(mktemp "${TMPDIR:-/tmp}/grkr-log.XXXXXX")
  rm -f "$LOG_PIPE"
  mkfifo "$LOG_PIPE"
  tee -a "$LOGFILE" < "$LOG_PIPE" &
  LOG_TEE_PID=$!
  exec >"$LOG_PIPE" 2>&1
else
  exec >>"$LOGFILE" 2>&1
fi

usage() {
  echo "Usage: grkr init <project-id> | grkr --issue <number> | grkr --project <id>"
  echo "Example: grkr init 42"
  echo "Example: grkr --issue 1"
  echo "Example: grkr --project 42"
  exit 1
}

MAX_FILE_LINES=1000
VALIDATION_OK=0

MODE=${1:-}
case "$MODE" in
  init)
    [ -n "${2:-}" ] || usage
    ID="$2"
    ;;
  --issue|--project)
    [ -n "${2:-}" ] || usage
    ID="$2"
    ;;
  *)
    usage
    ;;
esac

attach_issue_logs() {
  local issue=${CURRENT_ISSUE:-}
  [ -n "$issue" ] || return 0
  [ -f "$LOGFILE" ] || return 0
  gh issue comment "$issue" --body-file "$LOGFILE" >/dev/null 2>&1 || true
}

cleanup_on_exit() {
  [ -n "${CURRENT_PROMPT_FILE:-}" ] && rm -f "$CURRENT_PROMPT_FILE" 2>/dev/null || true
  if [ "${ATTACH_ISSUE_LOGS:-0}" -eq 1 ]; then
    attach_issue_logs
  fi
  [ -n "${LOG_PIPE:-}" ] && rm -f "$LOG_PIPE" 2>/dev/null || true
  [ -n "${LOG_TEE_PID:-}" ] && kill "$LOG_TEE_PID" 2>/dev/null || true
}

trap cleanup_on_exit EXIT

if [ "$MODE" = "init" ]; then
  doctor_init
  if doctor_create_config "$ID"; then
    echo "✅ Created config: $GRKR_CONFIG_FILE"
    exit 0
  fi
  exit 1
fi

if doctor_validate "$MODE" "$ID"; then
  VALIDATION_OK=1
fi

if [ "$MODE" = "--issue" ]; then
  ISSUE="$ID"
fi

if [ "$VALIDATION_OK" -eq 1 ]; then
  if [ -n "$(git status --porcelain --untracked-files=all | grep -vE '^.. \.grkr(/|$)')" ]; then
    echo "❌ Working directory is not clean. Commit or stash changes first."
    exit 1
  fi
fi

check_file_line_limit() {
  local file
  local line_count
  local violations=0
  while IFS= read -r -d '' file; do
    [ -n "$file" ] || continue
    line_count=$(git show ":$file" | wc -l | tr -d '[:space:]')
    if [ "$line_count" -gt "$MAX_FILE_LINES" ]; then
      echo "❌ $file has $line_count lines. Files must be $MAX_FILE_LINES lines or fewer."
      violations=1
    fi
  done < <(git diff --cached --name-only --diff-filter=ACMR -z)
  return $violations
}

extract_codex_pr_body() {
  local codex_output_file=$1
  local pr_body_file=$2
  local body=$3
  local title=$4
  local issue=$5
  local url=$6

  if [ -s "$codex_output_file" ]; then
    awk '
      /^## / {found=1}
      found {print}
    ' "$codex_output_file" > "$pr_body_file"
    if [ -s "$pr_body_file" ]; then
      if ! grep -Fq "Fixes #$issue" "$pr_body_file"; then
        cat >> "$pr_body_file" << EOF

Fixes #$issue

Issue: [#$issue]($url)
EOF
      fi
      return 0
    fi
  fi

  cat > "$pr_body_file" << EOF
## Detailed description of the task

$title

$body

## Implementation plan details

- Review the issue and repository context.
- Make the smallest focused change needed.
- Verify the change with the available automated tests.

## Testing results

- Functional testing performed: the launcher completed the issue workflow and created this PR.

Fixes #$issue

Issue: [#$issue]($url)
EOF
}

publish_issue_changes() {
  local ISSUE=$1
  local TITLE=$2
  local URL=$3
  local BODY=$4
  local CODEX_OUTPUT_FILE=$5
  local PR_BODY_FILE

  echo "🔄 Auto-committing, pushing and creating PR..."
  git add .
  if git diff --cached --quiet; then
    echo "No changes for #$ISSUE"
    return 0
  fi

  if ! check_file_line_limit; then
    echo "❌ Commit aborted due to file size limit."
    return 1
  fi

  git commit -m "feat: implement #$ISSUE - $TITLE"
  git push -u origin "issue-$ISSUE"
  PR_BODY_FILE=$(mktemp "${TMPDIR:-/tmp}/grkr-pr-body.XXXXXX")
  extract_codex_pr_body "$CODEX_OUTPUT_FILE" "$PR_BODY_FILE" "$BODY" "$TITLE" "$ISSUE" "$URL"
  PR_URL=$(gh pr create --title "$TITLE" --body-file "$PR_BODY_FILE")
  echo "✅ PR created: $PR_URL"
  gh issue edit "$ISSUE" --add-label "implemented" || true
  gh issue edit "$ISSUE" --remove-label "todo" || true
  rm -f "$PR_BODY_FILE"
}

process_issue() {
  local ISSUE=$1
  local prompt_file
  if [ "$VALIDATION_OK" -ne 1 ]; then
    echo "⚠️ Validation failed; skipping issue #$ISSUE."
    return 1
  fi
  echo "📋 Fetching issue #$ISSUE..."
  ISSUE_JSON=$(gh issue view "$ISSUE" --json title,body,url,number 2>&1)
  if echo "$ISSUE_JSON" | grep -q "Could not resolve"; then
    echo "❌ Issue #$ISSUE not found."
    return 1
  fi
  TITLE=$(echo "$ISSUE_JSON" | jq -r '.title')
  BODY=$(echo "$ISSUE_JSON" | jq -r '.body // "No description provided."')
  URL=$(echo "$ISSUE_JSON" | jq -r '.url')
  echo "📝 Issue: $TITLE"
  echo "🔗 $URL"
  BRANCH="issue-$ISSUE"
  CURRENT_ISSUE="$ISSUE"
  ATTACH_ISSUE_LOGS=1
  if git show-ref --verify --quiet "refs/heads/$BRANCH"; then
    echo "⚠️ Branch $BRANCH already exists locally. Checking it out..."
    git checkout --ignore-other-worktrees "$BRANCH"
  elif git ls-remote --heads origin "$BRANCH" | grep -q "$BRANCH"; then
    echo "⚠️ Branch $BRANCH already exists remotely. Checking it out..."
    git checkout --ignore-other-worktrees -t "origin/$BRANCH"
  else
    git checkout -b "$BRANCH"
    echo "🌿 Created and switched to branch: $BRANCH"
  fi
  prompt_file=$(mktemp "${TMPDIR:-/tmp}/grkr-prompt.XXXXXX")
  CURRENT_PROMPT_FILE="$prompt_file"
  cat > "$prompt_file" << EOF
Implement the GitHub issue described below using the Codex coding agent best practices.

**Issue #$ISSUE: $TITLE**
**URL:** $URL

**Description:**
$BODY

**Expected final response:**
## Detailed description of the task
## Implementation plan details
## Testing results
- Functional testing performed

---

**Instructions for you:**
1. First explore the codebase using available tools (grep, glob, read, etc.) to understand the current structure and conventions.
2. Follow the project's code style, naming conventions, and architecture.
3. Make minimal, focused changes.
4. Do not add comments unless specifically asked.
5. After changes, run linting and tests if available (use the bash tool).
6. Be concise in your responses.
7. When done, the changes should fully address the issue.

Begin by analyzing the project.
EOF
  echo "🚀 Running codex to implement the issue..."
  echo "Prompt saved to $prompt_file for reference."
  codex_output_file=$(mktemp "${TMPDIR:-/tmp}/grkr-codex.XXXXXX")
  codex exec --full-auto --cd "$(pwd)" < "$prompt_file" >"$codex_output_file" 2>&1
  cat "$codex_output_file"
  echo ""
  echo "✅ codex has finished implementing the changes."
  publish_issue_changes "$ISSUE" "$TITLE" "$URL" "$BODY" "$codex_output_file"
  rm -f "$prompt_file"
  CURRENT_PROMPT_FILE=""
  rm -f "$codex_output_file"
  ATTACH_ISSUE_LOGS=0
  attach_issue_logs
}

if [ "$MODE" = "--project" ]; then
  PROJECT="$ID"
  echo "🔄 Starting infinite loop watcher for project $PROJECT..."
  while true; do
    if [ "$VALIDATION_OK" -ne 1 ]; then
      echo "⚠️ Validation failed; skipping mutating operations."
      echo "⏳ Sleeping 30 seconds..."
      sleep 30
      continue
    fi
    echo "🔍 Querying issues in todo state..."
    TODO_ISSUES=$(gh issue list --state open --json number,title,projectItems | jq -r '.[] | select(.projectItems | any(.status.name == "Todo")) | .number')
    for ISSUE in $TODO_ISSUES; do
      echo "📋 Found todo issue #$ISSUE, implementing..."
      process_issue "$ISSUE"
    done
    echo "⏳ Sleeping 30 seconds..."
    sleep 30
  done
fi

if [ "$MODE" = "--issue" ]; then
  process_issue "$ISSUE"
fi
