#!/bin/bash
set -e

resolve_script_path() {
  local source_path=$1
  local source_dir

  while [ -L "$source_path" ]; do
    source_dir=$(cd "$(dirname "$source_path")" && pwd)
    source_path=$(readlink "$source_path")
    case "$source_path" in
      /*) ;;
      *) source_path="$source_dir/$source_path" ;;
    esac
  done

  printf '%s\n' "$source_path"
}

SCRIPT_PATH=$(resolve_script_path "${BASH_SOURCE[0]}")
SCRIPT_DIR=$(cd "$(dirname "$SCRIPT_PATH")" && pwd)
. "$SCRIPT_DIR/doctor.sh"
. "$SCRIPT_DIR/grkr-project-status.sh"
. "$SCRIPT_DIR/grkr-issue-workflow.sh"
. "$SCRIPT_DIR/lib/refusal_paths.sh"
. "$SCRIPT_DIR/lib/task_progress.sh"
. "$SCRIPT_DIR/lib/issue_shared.sh"
. "$SCRIPT_DIR/lib/linear_issue.sh"
. "$SCRIPT_DIR/lib/github_issue.sh"
. "$SCRIPT_DIR/grkr-task-slug.sh"

usage() {
  local exit_code=${1:-1}
  echo "Usage: grkr init <project-id> | grkr --issue <number> | grkr --linear-issue <identifier> | grkr --project <id>"
  echo "Example: grkr init 42"
  echo "Example: grkr --issue 1"
  echo "Example: grkr --linear-issue ENG-123"
  echo "Example: grkr --project 42"
  exit "$exit_code"
}

case "${1:-}" in
  --help|-h|help)
    usage 0
    ;;
esac

mkdir -p "${HOME:-.}/.grkr/logs"
LOGFILE="${HOME:-.}/.grkr/logs/grkr-$(date +%Y%m%d-%H%M%S).log"
CURRENT_ISSUE=""
CURRENT_PROMPT_FILE=""
CURRENT_ISSUE_WORKTREE=""
ATTACH_ISSUE_LOGS=0
PR_URL=""
BRANCH_URL=""
if command -v tee >/dev/null 2>&1; then
  LOG_PIPE=$(mktemp "${TMPDIR:-/tmp}/grkr-log.XXXXXX")
  rm -f "$LOG_PIPE"
  mkfifo "$LOG_PIPE"
  tee -a "$LOGFILE" < "$LOG_PIPE" &
  LOG_TEE_PID=$!
  exec >"$LOG_PIPE" 2>&1
else
  exec >>"$LOGFILE" 2>&1
fi
MAX_FILE_LINES=1000
MAX_PR_BODY_CHARS=60000
VALIDATION_OK=0
TASKS_DIR=""
. "$SCRIPT_DIR/grkr-templates.sh"

MODE=${1:-}
case "$MODE" in
  init)
    [ -n "${2:-}" ] || usage
    ID="$2"
    ;;
  --issue|--project|--linear-issue)
    [ -n "${2:-}" ] || usage
    ID="$2"
    ;;
  *)
    usage
    ;;
esac

cleanup_on_exit() {
  [ -n "${CURRENT_PROMPT_FILE:-}" ] && rm -f "$CURRENT_PROMPT_FILE" 2>/dev/null || true
  if [ "${ATTACH_ISSUE_LOGS:-0}" -eq 1 ]; then
    attach_issue_logs
  fi
  [ -n "${LOG_PIPE:-}" ] && rm -f "$LOG_PIPE" 2>/dev/null || true
  [ -n "${LOG_TEE_PID:-}" ] && kill "$LOG_TEE_PID" 2>/dev/null || true
}

trap cleanup_on_exit EXIT

if [ "$MODE" = "init" ]; then
  doctor_init
  if doctor_create_config "$ID"; then
    echo "✅ Created config: $GRKR_CONFIG_FILE"
    exit 0
  fi
  exit 1
fi

if doctor_validate "$MODE" "$ID"; then
  VALIDATION_OK=1
fi

if [ "$MODE" = "--issue" ]; then
  ISSUE="$ID"
fi

if [ "$MODE" = "--linear-issue" ]; then
  LINEAR_ISSUE_ID="$ID"
fi

if [ "$VALIDATION_OK" -eq 1 ]; then
  if [ -n "$(git status --porcelain --untracked-files=all | grep -vE '^.. \.grkr(/|$)')" ]; then
    echo "⚠️ Working directory is not clean. Continuing with the existing changes in the worktree."
  fi
fi

process_issue() {
  local ISSUE=$1
  GITHUB_IMPL_REFUSED=0
  # 1. validate + fetch + task dir/progress bootstrap (lib helper)
  bootstrap_github_issue_task "$ISSUE" || return 1
  # 2. research/plan checkpoints (already in lib)
  ensure_checkpoint_stage research "$ISSUE" "$ISSUE_JSON" "$TASK_SLUG" "$TASK_DIR" "$TITLE" "$BODY" "$URL" "$PROGRESS_FILE" || return 1
  ensure_checkpoint_stage plan "$ISSUE" "$ISSUE_JSON" "$TASK_SLUG" "$TASK_DIR" "$TITLE" "$BODY" "$URL" "$PROGRESS_FILE" || return 1
  # 3. prepare worktree + decision codex + decision_gate (lib helper)
  run_github_decision_stage || return 1
  # 4. refuse path cleanup (lib helper) OR proceed
  if [ "${IMPLEMENTATION_DECISION:-}" != "proceed" ]; then
    handle_github_decision_refuse
    return 0
  fi
  # 5. move in progress + implement codex + implementation-refusal path (lib helper)
  run_github_implement_stage || {
    CURRENT_ISSUE_WORKTREE=""
    return 1
  }
  if [ "${GITHUB_IMPL_REFUSED:-0}" = "1" ]; then
    return 0
  fi
  # 6. ensure_publishable_file_sizes (shared in issue_shared.sh)
  ensure_publishable_file_sizes "$ISSUE" "$TITLE" "$TASK_SLUG" "$CURRENT_PROMPT_FILE" "$TASK_DIR/implementation.log" || {
    CURRENT_ISSUE_WORKTREE=""
    return 1
  }
  # 7. ensure_test_checkpoint (lib)
  ensure_test_checkpoint "$ISSUE" "$ISSUE_JSON" "$TASK_SLUG" "$TASK_DIR" "$TITLE" "$PROGRESS_FILE" || {
    CURRENT_ISSUE_WORKTREE=""
    return 1
  }
  # 8. publish_issue_changes (lib)
  if ! publish_issue_changes "$ISSUE" "$TITLE" "$URL" "$BODY" "$TASK_DIR/implementation.log" "$BRANCH"; then
    CURRENT_ISSUE_WORKTREE=""
    echo "⚠️ Issue #$ISSUE changes were not published."
    return 1
  fi
  # 9. mark complete + move done + post_completion (thin calls / small lib helper)
  finalize_github_issue_complete
  # 10. attach logs (via finalize)
}

if [ "$MODE" = "--project" ]; then
  PROJECT="$ID"
  echo "🔄 Starting infinite loop watcher for project $PROJECT..."
  while true; do
    if [ "$VALIDATION_OK" -ne 1 ]; then
      echo "⚠️ Validation failed; skipping mutating operations."
      echo "⏳ Sleeping 30 seconds..."
      sleep 30
      continue
    fi
    echo "🔍 Querying issues in todo state..."
    TODO_ISSUES=$(gh issue list --state open --json number,title,projectItems | jq -r --arg todo "$TODO_VALUE" '.[] | select(.projectItems | any(.status.name == $todo)) | .number')
    for ISSUE in $TODO_ISSUES; do
      echo "📋 Found todo issue #$ISSUE, implementing..."
      if ! process_issue "$ISSUE"; then
        echo "⚠️ Issue #$ISSUE failed during processing. Continuing to the next issue."
      fi
    done
    echo "⏳ Sleeping 30 seconds..."
    sleep 30
  done
fi

if [ "$MODE" = "--issue" ]; then
  process_issue "$ISSUE"
fi

if [ "$MODE" = "--linear-issue" ]; then
  process_linear_issue "$LINEAR_ISSUE_ID"
fi
