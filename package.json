{
  "name": "grkr",
  "version": "0.1.0",
  "description": "AI-powered CLI that reads a GitHub/Linear issue and uses a swappable coding agent (Codex or Grok) to implement the changes.",
  "bin": {
    "grkr": "bin/grkr",
    "doctor.sh": "bin/doctor.sh",
    "robot-main.sh": "bin/robot-main.sh"
  },
  "scripts": {
    "sync:spec": "bash scripts/sync-spec.sh",
    "test": "bash scripts/npm-test.sh",
    "test:gleam": "bash scripts/bootstrap-gleam.sh && PATH=\"$PWD/.automation-local:$PATH\" gleam test"
  },
  "keywords": ["cli", "github", "codex", "ai", "coding-agent"],
  "author": "stepango",
  "license": "MIT"
}
